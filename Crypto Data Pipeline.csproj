    <RootNamespace>CryptoDataPipeline</RootNamespace>
    <UserSecretsId>f69be159-054d-44b7-9ad6-2437d93af02f</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.10" />
